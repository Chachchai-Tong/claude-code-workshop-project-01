{
  "name": "claude-code-workshop",
  "version": "1.0.0",
  "description": "Sample project for Claude Code Workshop — contains intentional bugs for learning",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "node --watch src/app.js",
    "test": "jest --verbose",
    "test:watch": "jest --watch",
    "lint": "eslint src/ --ext .js",
    "db:seed": "node src/models/seed.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "uuid": "^9.0.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^6.3.3"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.js"],
    "setupFiles": ["./tests/setup.js"]
  }
}
